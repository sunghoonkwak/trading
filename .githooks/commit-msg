#!/bin/sh

commit_msg_file="$1"
max_subject_length=50
max_body_length=72

subject="$(awk 'NF && $0 !~ /^#/ { print; exit }' "$commit_msg_file")"
subject_length=${#subject}

if [ "$subject_length" -gt "$max_subject_length" ]; then
  echo "Commit subject is ${subject_length} chars; max is ${max_subject_length}." >&2
  echo "Subject: $subject" >&2
  exit 1
fi

awk -v max="$max_body_length" '
  NR == 1 { next }
  /^#/ { next }
  length($0) > max {
    printf "Commit body line %d is %d chars; max is %d.\n", NR, length($0), max > "/dev/stderr"
    failed = 1
  }
  END { exit failed }
' "$commit_msg_file"

awk '
  /^#/ { next }
  !seen_subject {
    seen_subject = 1
    next
  }
  !seen_separator {
    if ($0 != "") {
      printf "Commit body must be separated from the subject by a blank line before line %d.\n", NR > "/dev/stderr"
      failed = 1
    }
    seen_separator = 1
    next
  }
  $0 == "" {
    if (previous_body_bullet) {
      blank_after_bullet = 1
    }
    next
  }
  /^- / && blank_after_bullet {
    printf "Commit body has a blank line between bullet items before line %d.\n", NR > "/dev/stderr"
    failed = 1
  }
  {
    previous_body_bullet = ($0 ~ /^- /)
    blank_after_bullet = 0
  }
  END { exit failed }
' "$commit_msg_file"
